# Google OAuth credentials
# Get these from https://console.developers.google.com/
KOTBUSTA_GOOGLE_CLIENT_ID=your_google_client_id_here
KOTBUSTA_GOOGLE_CLIENT_SECRET=your_google_client_secret_here
KOTBUSTA_GOOGLE_REDIRECT_URI=http://localhost:8080/callback

# Session sign and encrypt keys
# Keys will be generated by the app, if none provided
KOTBUSTA_SESSION_SIGN_KEY=
KOTBUSTA_SESSION_ENCRYPT_KEY=

# Path to SQLite database file (will be mounted inside the container)
KOTBUSTA_DB_PATH=/data/db/kotbusta.db
KOTBUSTA_LUCENE_INDEX_PATH=/data/db/lucene

# Admin email address used for granting administrative privileges
KOTBUSTA_ADMIN_EMAIL=your_admin_email_here

# Path to store SQLite database on host
KOTBUSTA_DB_DATA_PATH_LOCAL=/mnt/kotbusta-db

# Path with a library stored in Flibusta format
KOTBUSTA_BOOKS_DATA_PATH_LOCAL=/mnt/flibusta

# Optional semantic search/enrichment model. Mount this directory to the same
# path in docker-compose if enabled; leave blank to use full-text search only.
KOTBUSTA_EMBEDDING_MODEL_PATH=
KOTBUSTA_EMBEDDING_MODEL_PATH_LOCAL=/mnt/kotbusta-embedding-model

# Optional bearer token for /metrics. Leave blank for unauthenticated metrics.
KOTBUSTA_METRICS_TOKEN=

# Book enrichment worker tuning (optional; defaults shown)
# KOTBUSTA_ENRICH_BATCH_SIZE=32
# KOTBUSTA_ENRICH_PARALLELISM=4
# KOTBUSTA_ENRICH_INTERVAL_MS=60000
# KOTBUSTA_ENRICH_REBUILD_EVERY=5000

# --- Send to Kindle (optional) ---
# The Kindle send worker only starts when KOTBUSTA_SES_SENDER_EMAIL is set.
# Leave these blank to run without Send-to-Kindle.
# Verified Amazon SES sender address (the "From" of book emails):
KOTBUSTA_SES_SENDER_EMAIL=
# AWS credentials/region for the SES client:
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional tuning (defaults shown): daily quota, batch size, retries, poll interval (ms)
# KOTBUSTA_KINDLE_DAILY_QUOTA=20
# KOTBUSTA_KINDLE_WORKER_BATCH_SIZE=10
# KOTBUSTA_KINDLE_WORKER_MAX_RETRIES=5
# KOTBUSTA_KINDLE_WORKER_INTERVAL_MS=30000

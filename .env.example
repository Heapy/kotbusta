# Google OAuth credentials
# Get these from https://console.developers.google.com/
KOTBUSTA_GOOGLE_CLIENT_ID=your_google_client_id_here
KOTBUSTA_GOOGLE_CLIENT_SECRET=your_google_client_secret_here
KOTBUSTA_GOOGLE_REDIRECT_URI=http://localhost:8080/callback

# Session sign and encrypt keys
# Keys will be generated by the app, if none provided
KOTBUSTA_SESSION_SIGN_KEY=
KOTBUSTA_SESSION_ENCRYPT_KEY=

# Path to SQLite database file
KOTBUSTA_DB_PATH=./.data/kotbusta.db

# Path to the embedded Lucene index
KOTBUSTA_LUCENE_INDEX_PATH=./.data/lucene

# Optional path to a local ONNX int8 multilingual-e5-small model directory.
# Leave blank to disable semantic search/enrichment and use full-text search only.
KOTBUSTA_EMBEDDING_MODEL_PATH=

# Book enrichment worker tuning (optional; defaults shown)
# KOTBUSTA_ENRICH_BATCH_SIZE=32
# KOTBUSTA_ENRICH_PARALLELISM=4
# KOTBUSTA_ENRICH_INTERVAL_MS=60000
# KOTBUSTA_ENRICH_REBUILD_EVERY=5000

# Optional bearer token for /metrics. Leave blank for unauthenticated metrics.
KOTBUSTA_METRICS_TOKEN=

# Books data path (required - path to your flibusta data)
KOTBUSTA_BOOKS_DATA_PATH=/path/to/your/flibusta/books

# Admin email address used for granting administrative privileges
KOTBUSTA_ADMIN_EMAIL=your_admin_email_here

# Development-only variables for frontend development
KOTBUSTA_STATIC_FILES_PATH=src/main/resources/static

# AWS access credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Email sender address (verified in Amazon SES). The Send-to-Kindle worker only
# starts when this is set; leave blank to run without Send-to-Kindle.
KOTBUSTA_SES_SENDER_EMAIL=test@example.com

# Send-to-Kindle worker tuning (optional; defaults shown)
# KOTBUSTA_KINDLE_DAILY_QUOTA=20
# KOTBUSTA_KINDLE_WORKER_BATCH_SIZE=10
# KOTBUSTA_KINDLE_WORKER_MAX_RETRIES=5
# KOTBUSTA_KINDLE_WORKER_INTERVAL_MS=30000

# Featured books worker tuning (optional; defaults shown).
# Scrapes LiveLib's all-time "Топ 100" list for the home page's featured
# section; set the interval to 0 to disable.
# KOTBUSTA_FEATURED_WORKER_INTERVAL_MS=86400000
# KOTBUSTA_FEATURED_WORKER_PAGE_COUNT=1
